<div id='@{:SM_CTRL_ID}' name='@{:SM_CTRL_ID}' class='sm-ctrl-box @{:SM_CTRL_BOX}' @{:SM_CTRL_ATTR}>
	@{:SM_CTRL_TEXT}
</div>

<!-- CONTROLTYPE: LOCATION -->

<!-- CONTROLTYPE: MEMO -->
<div id='@{:SM_CTRL_ID}-box' name='@{:SM_CTRL_ID}-box' class='sm-ctrl-box @{:SM_CTRL_BOX}' sm-for='@{:SM_CTRL_ID}'>
	<label id='@{:SM_CTRL_ID}-lbl' name='@{:SM_CTRL_ID}-lbl' class='sm-ctrl-label' sm-for='@{:SM_CTRL_ID}'>@{:SM_CTRL_HTML}</label>
	<textarea id='@{:SM_CTRL_ID}' name='@{:SM_CTRL_ID}' type='text' class='form-control sm-form-control sm-ctrl-textarea @{:SM_CTRL_CLASS}'
			  onfocus='$$_OnFocus(this)' onblur='$$_OnBlur(this)' @{:SM_CTRL_ATTR} />@{:SM_CTRL_VALUE}</textarea>
	<small id='@{:SM_CTRL_ID}-err' name='@{:SM_CTRL_ID}-err' class='sm-ctrl-error' rows='@{:SM_CTRL_ROWS}' sm-for='@{:SM_CTRL_ID}'>@{:SM_CTRL_ERR_MSG}</small>
</div>

