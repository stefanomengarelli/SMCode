<!-- CONTROLTYPE: TEXT -->
<div id='@{:SM_CTRL_ID}-box' name='@{:SM_CTRL_ID}-box' class='sm-ctrl-box @{:SM_CTRL_BOX}' sm-for='@{:SM_CTRL_ID}'>
	<label id='@{:SM_CTRL_ID}-lbl' name='@{:SM_CTRL_ID}-lbl' class='sm-ctrl-label' sm-for='@{:SM_CTRL_ID}'>@{:SM_CTRL_HTML}</label>
	<input type='text' id='@{:SM_CTRL_ID}' name='@{:SM_CTRL_ID}' class='form-control sm-ctrl-input @{:SM_CTRL_CLASS}' value='@{:SM_CTRL_VALUE}'
		   @{:SM_CTRL_ATTR} onfocus='$$_OnFocus(this)' onblur='$$_OnBlur(this)' />
	<small id='@{:SM_CTRL_ID}-err' name='@{:SM_CTRL_ID}-err' class='sm-ctrl-error sm-hidden' sm-for='@{:SM_CTRL_ID}'>@{:SM_CTRL_ERR_MSG}</small>
</div>

<!-- CONTROLTYPE: TIME -->
<div id='@{:SM_CTRL_ID}-box' name='@{:SM_CTRL_ID}-box' class='sm-ctrl-box @{:SM_CTRL_BOX}' sm-for='@{:SM_CTRL_ID}'>
	<label id='@{:SM_CTRL_ID}-lbl' name='@{:SM_CTRL_ID}-lbl' class='sm-ctrl-label' sm-for='@{:SM_CTRL_ID}'>@{:SM_CTRL_HTML}</label>
	<input type='time' id='@{:SM_CTRL_ID}' name='@{:SM_CTRL_ID}' class='form-control sm-ctrl-input @{:SM_CTRL_CLASS}' value='@{:SM_CTRL_VALUE}'
		   @{:SM_CTRL_ATTR} onfocus='$$_OnFocus(this)' onblur='$$_OnBlur(this)' />
	<small id='@{:SM_CTRL_ID}-err' name='@{:SM_CTRL_ID}-err' class='sm-ctrl-error sm-hidden' sm-for='@{:SM_CTRL_ID}'>@{:SM_CTRL_ERR_MSG}</small>
</div>

