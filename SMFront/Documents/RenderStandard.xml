<!-- RENDER TEMPLATES / FRAMEWORK: STANDARD
        
     Macros
     @{:SM_CTRL_ATTR}    : default control attributes 
     @{:SM_CTRL_BOX}     : default control box class list
     @{:SM_CTRL_CHECKED  : control checked attribute if value is true
     @{:SM_CTRL_CLASS}   : default control class list
     @{:SM_CTRL_ERR_MSG} : default control error message
     @{:SM_CTRL_HTML}    : control text converted with HTML escapes
     @{:SM_CTRL_ID}      : control id
     @{:SM_CTRL_TEXT}    : control raw text 
     @{:SM_CTRL_ROWS}    : control rows height
     @{:SM_CTRL_VALUE}   : control value converted with HTML escapes

  -->

<!-- CONTROLTYPE: ACCORDION -->
<!-- CONTROLTYPE: ATTACHMENT -->
<!-- CONTROLTYPE: BLOB -->
<!-- CONTROLTYPE: BUTTON -->
<!-- CONTROLTYPE: CAPTION -->
<div id='@{:SM_CTRL_ID}-box' name='@{:SM_CTRL_ID}-box' class='sm-ctrl-box @{:SM_CTRL_BOX}' sm-for='@{:SM_CTRL_ID}'>
    <span id='@{:SM_CTRL_ID}' name='@{:SM_CTRL_ID}' class='col-12 sm-ctrl-label' @{:SM_CTRL_ATTR}>@{:SM_CTRL_HTML}</span>
</div>

<!-- CONTROLTYPE: CHECK -->
<div id='@{:SM_CTRL_ID}-box' name='@{:SM_CTRL_ID}-box' class='sm-ctrl-box @{:SM_CTRL_BOX}' sm-for='@{:SM_CTRL_ID}'>
    <div id='@{:SM_CTRL_ID}-div' name='@{:SM_CTRL_ID}-div' class='sm-ctrl-check-div' sm-for='@{:SM_CTRL_ID}'>
        <input type='checkbox' id='@{:SM_CTRL_ID}' name='@{:SM_CTRL_ID}' class='form-control sm-ctrl-input @{:SM_CTRL_CLASS}' @{:SM_CTRL_CHECKED}
               @{:SM_CTRL_ATTR} onfocus='$$_OnFocus(this)' onblur='$$_OnBlur(this)' />
        <label id='@{:SM_CTRL_ID}-lbl' name='@{:SM_CTRL_ID}-lbl' class='sm-ctrl-label' sm-for='@{:SM_CTRL_ID}'>@{:SM_CTRL_HTML}</label>
        <small id='@{:SM_CTRL_ID}-err' name='@{:SM_CTRL_ID}-err' class='sm-ctrl-error sm-hidden' sm-for='@{:SM_CTRL_ID}'>@{:SM_CTRL_ERR_MSG}</small>
    </div>
</div>

<!-- CONTROLTYPE: COMBO -->

<!-- CONTROLTYPE: DATE -->

<!-- CONTROLTYPE: DETAILS -->
<div id='@{:SM_CTRL_ID}' name='@{:SM_CTRL_ID}' class='sm-ctrl-details' @{:SM_CTRL_ATTR}>

<!-- CONTROLTYPE: ENDACCORDION -->

<!-- CONTROLTYPE: ENDDETAILS -->

<!-- CONTROLTYPE: ENDPANEL -->

<!-- CONTROLTYPE: ENDREPEAT -->

<!-- CONTROLTYPE: ENDROW -->

